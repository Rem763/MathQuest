<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.quest.scene.MapController" prefWidth="1280" prefHeight="720" style="-fx-background-color: linear-gradient(to bottom, #173a3a, #2f6d4e);">
    <children>
        <VBox alignment="CENTER" spacing="18" prefWidth="1280" prefHeight="720">
            <padding>
                <Insets top="24" right="36" bottom="24" left="36" />
            </padding>
            <children>
                <Label text="世界地图" style="-fx-font-size: 40px; -fx-text-fill: #fff2b2; -fx-font-weight: bold;" />
                <Label fx:id="statusLabel" text="玩家信息" style="-fx-font-size: 16px; -fx-text-fill: #ffffff; -fx-background-color: rgba(0,0,0,0.28); -fx-padding: 8 14 8 14; -fx-border-color: #f7d66b; -fx-border-width: 2;" />

                <StackPane prefWidth="1040" prefHeight="420" style="-fx-background-color: rgba(0,0,0,0.18); -fx-border-color: #f7d66b; -fx-border-width: 3;">
                    <children>
                        <Rectangle width="1040" height="420" fill="transparent" />
                        <VBox alignment="CENTER" spacing="10">
                            <children>
                                <Label text="选择一个关卡节点" style="-fx-font-size: 18px; -fx-text-fill: #fff2b2; -fx-font-weight: bold;" />
                                <HBox alignment="CENTER" spacing="18">
                                    <children>
                                        <VBox alignment="CENTER" spacing="6">
                                            <children>
                                                <Circle radius="22" fill="#f7d66b" stroke="#2b1d10" strokeWidth="4" />
                                                <Label text="1-1" style="-fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold;" />
                                                <Button fx:id="stage1Button" text="进入" onAction="#goStage1" prefWidth="96" prefHeight="40" />
                                            </children>
                                        </VBox>
                                        <Line startX="0" startY="0" endX="120" endY="0" stroke="#f7d66b" strokeWidth="6" />
                                        <VBox alignment="CENTER" spacing="6">
                                            <children>
                                                <Circle radius="22" fill="#f7d66b" stroke="#2b1d10" strokeWidth="4" />
                                                <Label text="1-2" style="-fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold;" />
                                                <Button fx:id="stage2Button" text="进入" onAction="#goStage2" prefWidth="96" prefHeight="40" />
                                            </children>
                                        </VBox>
                                        <Line startX="0" startY="0" endX="120" endY="0" stroke="#f7d66b" strokeWidth="6" />
                                        <VBox alignment="CENTER" spacing="6">
                                            <children>
                                                <Circle radius="22" fill="#f7d66b" stroke="#2b1d10" strokeWidth="4" />
                                                <Label text="1-3" style="-fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold;" />
                                                <Button fx:id="stage3Button" text="进入" onAction="#goStage3" prefWidth="96" prefHeight="40" />
                                            </children>
                                        </VBox>
                                        <Line startX="0" startY="0" endX="120" endY="0" stroke="#f7d66b" strokeWidth="6" />
                                        <VBox alignment="CENTER" spacing="6">
                                            <children>
                                                <Circle radius="28" fill="#d94b4b" stroke="#2b1d10" strokeWidth="5" />
                                                <Label text="BOSS" style="-fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-font-weight: bold;" />
                                                <Button fx:id="bossButton" text="决战" onAction="#goBoss" prefWidth="96" prefHeight="40" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER" spacing="36">
                                    <padding>
                                        <Insets top="24" right="0" bottom="0" left="0" />
                                    </padding>
                                    <children>
                                        <Label text="森林" style="-fx-text-fill: #ffffff; -fx-font-size: 14px;" />
                                        <Label text="河湾" style="-fx-text-fill: #ffffff; -fx-font-size: 14px;" />
                                        <Label text="山道" style="-fx-text-fill: #ffffff; -fx-font-size: 14px;" />
                                        <Label text="城门" style="-fx-text-fill: #ffffff; -fx-font-size: 14px;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </StackPane>

                <HBox alignment="CENTER" spacing="14">
                    <children>
                        <Button fx:id="normalButton" text="普通" onAction="#setNormalDifficulty" prefWidth="160" prefHeight="42" />
                        <Button fx:id="hardButton" text="困难" onAction="#setHardDifficulty" prefWidth="160" prefHeight="42" />
                        <Button text="返回标题" onAction="#backToTitle" prefWidth="160" prefHeight="42" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
